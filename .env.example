# If unset, the app uses PGlite at ./mock.db
# DATABASE_URL=postgres://user:pass@host:5432/db?sslmode=require

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-me-with-a-long-random-string

# Dev-only: skip OAuth, sign in as any email
NEXTAUTH_DEV_BYPASS=1

# Discord OAuth (prod)
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# ADMIN_DISCORD_IDS=comma,separated,discord,user,ids

# Redis (prod). If unset, MessageBus publish is a console-log no-op + dev table insert.
# REDIS_URL=redis://localhost:6379

# The namespace this site writes/reads under in player_data.data
COLLECTIONLOG_NAMESPACE=collectionlog
